<% if posts.empty? %>
<p class="text-muted">No posts yet.</p>
<% else %>
<ul class="list-group">
  <% posts.each do |post| %>
  <li class="list-group-item d-flex justify-content-between align-items-center">
    <a href="/posts/<%= post.id %>"><%= post.title %></a>
  </li>
  <% end %>
</ul>
<% end %>
