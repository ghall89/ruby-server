<section class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= post.title %></h1>
    <% if current_user && post.user_id == current_user.id %>
    <div class="d-flex gap-2">
      <a href="/posts/<%= post.id %>/edit" class="btn btn-outline-secondary"
        >Edit</a
      >
      <form action="/posts/<%= post.id %>" method="post">
        <input type="hidden" name="_method" value="DELETE" />
        <button type="submit" class="btn btn-outline-danger">Delete</button>
      </form>
    </div>
    <% end %>
  </div>
  <p class="text-muted">by: <%= poster.username %></p>
  <p><%= post.body %></p>
  <a href="/posts" class="text-muted">← Back to posts</a>

  <hr class="my-4" />
  <h2 class="mb-3">Replies</h2>
  <%= partial :_reply_form, { post_id: post.id, parent_id: nil } %>

  <% if replies.empty? %>
  <p class="text-muted">No replies!</p>
  <% else %> <% replies.each do |node| %> <%= render_replies(node) %> <% end %>
  <% end %>
</section>

<script>
  document.addEventListener("click", function (e) {
    if (!e.target.matches("[data-reply-toggle]")) return;
    const id = e.target.dataset.replyToggle;
    const target = document.getElementById("reply-form-" + id);
    document.querySelectorAll("[id^='reply-form-']").forEach(function (el) {
      if (el !== target) el.classList.add("d-none");
    });
    target.classList.toggle("d-none");
  });
</script>
